<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".MathQuizActivity">

    <!-- Difficulty Selection Screen -->
    <LinearLayout
        android:id="@+id/difficultySelector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Select Difficulty"
            android:textColor="#1A237E"
            android:textSize="34sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnEasy"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Easy"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnMedium"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Medium"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnHard"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Hard"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Game Container -->
    <LinearLayout
        android:id="@+id/gameContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <!-- Header: Score, Timer, Lives -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Score: 0"
                android:textColor="#1A237E"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- This is the TextView for the countdown timer -->
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10s"
                android:textColor="#D50000"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLives"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="❤️❤️❤️"
                android:textColor="#D50000"
                android:textSize="24sp" />

        </LinearLayout>

        <!-- Question -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="32dp"
                android:textColor="#000000"
                android:textSize="36sp"
                android:textStyle="bold"
                tools:text="What is 5 + 12 ?" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Wrapper to center the grid vertically -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Answer Options -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/answerGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:columnCount="2"
                app:rowCount="2"
                app:useDefaultMargins="true">

                <Button
                    android:id="@+id/btnAnswer1"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    tools:text="17" />

                <Button
                    android:id="@+id/btnAnswer2"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    tools:text="15" />

                <Button
                    android:id="@+id/btnAnswer3"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    tools:text="12" />

                <Button
                    android:id="@+id/btnAnswer4"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    tools:text="20" />

            </androidx.gridlayout.widget.GridLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

